<%= turbo_frame_tag :search do %>
  <%= render "books/searches/form", book: book %>

  <div class="search__results">
    <% if @pages.any? %>
      <% @pages.each do |page| %>
        <%= render "books/searches/result", page: page %>
      <% end %>
    <% else %>
      <p class="search__no_matches">No matches!</p>
    <% end %>
  </div>
<% end %>
