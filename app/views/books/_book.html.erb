<figure class="library__book">
  <%= link_to book, class: "txt-undecorated txt-ink flex flex-column gap-half" do %>
    <div class="flex-inline position-relative center">
      <%= image_tag book.cover.attached? ? book.cover : "default-cover.webp", alt: "Book cover", class: "book__cover" %>
      <%= turbo_frame_tag dom_id(book, :bookmark), src: book_bookmark_path(book) %>
    </div>
    <h2 class="margin-none flex flex-column txt-tight-lines txt-medium">
      <strong class="txt-large--responsive"><%= book.title %></strong>
      <small class="translucent txt-normal txt-medium--responsive"><%= book.author %></small>
    </h2>
  <% end %>
</figure>
